+# Detect openSUSE Leap
+IS_OPENSUSE=false
+if grep -qi 'opensuse-leap' /etc/os-release 2>/dev/null; then
+    IS_OPENSUSE=true
+fi
+
 function get_local_branch() {
     # Return active branch
     cd "${1}" 2>/dev/null || return 1
@@ -25,6 +31,44 @@
     git rev-parse --short=8 HEAD || return 1
 }
 
+
+function get_rpm_version() {
+    rpm -q --qf '%{VERSION}\n' "${1}" 2>/dev/null || return 1
+}
+
+function get_rpm_branch() {
+    rpm -q "${1}" >/dev/null 2>&1 || return 1
+    echo "master"
+}
+
+function get_rpm_hash() {
+    rpm -q "${1}" >/dev/null 2>&1 || return 1
+    echo ""
+}
+
+function get_local_version_or_rpm() {
+    if ${IS_OPENSUSE}; then
+        get_rpm_version "${2}" || get_local_version "${1}"
+    else
+        get_local_version "${1}"
+    fi
+}
+
+function get_local_branch_or_rpm() {
+    if ${IS_OPENSUSE}; then
+        get_rpm_branch "${2}" || get_local_branch "${1}"
+    else
+        get_local_branch "${1}"
+    fi
+}
+
+function get_local_hash_or_rpm() {
+    if ${IS_OPENSUSE}; then
+        get_rpm_hash "${2}" || get_local_hash "${1}"
+    else
+        get_local_hash "${1}"
+    fi
+}
 function get_remote_version() {
